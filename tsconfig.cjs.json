{
	"extends": "./tsconfig",
	"compilerOptions": {
		"module": "CommonJS",
		"moduleResolution": "bundler",
		"outDir": "dist/cjs",
		"noEmit": false,
		"declaration": false,
		"sourceMap": true
	},
	"exclude": [
		"./src/examples",
		"./src/tests/**/*",
		"./src/**/*.test.ts",
		"./src/temp/**/*",
		"./vite.config.mts"
	]
}
